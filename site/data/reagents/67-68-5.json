  "bench_knowledge": [
    {
      "rule_id": "warm_freeze_prone_liquid",
      "because": "Liquids with freeze points at or above 15\u00b0C (DMSO ~19\u00b0C, glycerol ~18\u00b0C) can solidify partially or fully in a 4\u00b0C cold room or on ice. Pipetting a partially-solidified liquid causes systematic volume errors. The physical_state guard prevents the rule from misfiring on solids whose melting point happens to be reported in freeze_point_C (e.g. NaOH pellets, PFA powder).",
      "cite": "Sigma-Aldrich DMSO Product Information Sheet 276855 (freeze point 18.45\u00b0C). Perry's Chemical Engineers' Handbook, 8th ed. (glycerol freeze point 17.8\u00b0C).",
      "confidence": "high"
    },
    {
      "rule_id": "skin_penetrant_hazard",
      "because": "Skin-penetrant reagents cross intact skin and can carry dissolved solutes transdermally. DMSO is the canonical example \u2014 contact with a DMSO drug stock is a real toxicity exposure route even through nitrile gloves with extended contact. 2-mercaptoethanol and acrylamide are similarly absorbed through skin. Nitrile gloves (not latex) are required; change gloves immediately after any spill; never work with these without gloves.",
      "cite": "NIOSH skin absorption hazard notes. Braue EH et al. (1999) Occup Environ Med: percutaneous absorption review.",
      "confidence": "low"
    }
  ],
