  "bench_knowledge": [
    {
      "rule_id": "pre_wet_volatile",
      "because": "High vapor pressure (\u22655 kPa at 20\u00b0C) causes significant evaporation inside the tip. Without pre-wetting, the headspace is dry air; the solvent flash-evaporates into it, creating a vapour cushion that compresses and releases unpredictably, drifting dispensed volume by 5\u201315%. Three aspirate-expel cycles saturate the headspace before the actual dispensing step. Fast dispense minimises dwell-time in the tip.",
      "cite": "Eppendorf Application Note: Pipetting Volatile Liquids, 2018. NIST WebBook CAS 64-17-5 (vapor pressure 5.95 kPa at 20\u00b0C).",
      "confidence": "high"
    },
    {
      "rule_id": "peroxide_forming_track",
      "because": "Ethers (diethyl ether, THF, dioxane) form shock-sensitive hydroperoxides on exposure to air and light via autoxidation. Peroxide concentration increases with time and is highest in the last few millilitres as the solvent evaporates. Opening a bottle without a peroxide test when the contents are old or unknown is a documented explosion hazard. Max 3-month working life after opening; test with commercial peroxide strips before each use; discard at 25 ppm peroxide or above.",
      "cite": "Jackson HL et al. (1998) Chem Health Safety 5(3): 16\u201318 (ether peroxide hazards). Prudent Practices in the Laboratory, NRC 2011, Ch. 6.",
      "confidence": "high"
    }
  ],
